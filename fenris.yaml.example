# FENRIS Configuration
# Copy to fenris.yaml and fill in your values.
# js-yaml does NOT expand ${ENV_VAR} — write values directly or rely on
# the env-var fallback path (recommended for Docker deployments).

server:
  port: 3200
  database_url: postgresql://fenris:CHANGE_ME_BEFORE_DEPLOY@postgres:5432/fenris

# Metrics Collection
monitors:
  system:
    enabled: true
    scrape_interval: 30s
    metrics:
      - cpu
      - memory
      - disk
      - network

  disk:
    paths:
      - path: /
        name: root
        warning_threshold: 85
        critical_threshold: 95
      - path: /var/lib/docker
        name: docker-data
        warning_threshold: 80
        critical_threshold: 90
      - path: /var/log
        name: logs
        warning_threshold: 85
        critical_threshold: 95

# Alert Channels
# Each channel has its own enabled flag and severity_levels filter.
# All enabled channels fire in parallel; one failure does not block others.
alerts:

  # Discord incoming webhook
  discord:
    enabled: true
    webhook_url: "https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"
    severity_levels:
      - warning
      - critical

  # Slack incoming webhook
  slack:
    enabled: false
    webhook_url: "https://hooks.slack.com/services/T.../B.../..."
    severity_levels:
      - warning
      - critical

  # Email via SMTP (e.g. Gmail, SendGrid, Postfix)
  email:
    enabled: false
    smtp_host: "smtp.gmail.com"
    smtp_port: 587
    smtp_secure: false        # true = TLS on connect (port 465); false = STARTTLS (587)
    username: ""              # SMTP login username (often same as 'from' address)
    password: ""              # SMTP password or app-password
    from: "fenris@yourdomain.com"
    to:
      - "admin@yourdomain.com"
    severity_levels:
      - warning
      - critical

  # Anomaly and threshold values that trigger alerts
  thresholds:
    cpu:
      warning: 75
      critical: 95
    memory:
      warning: 80
      critical: 90
    disk:
      warning: 85
      critical: 95
    network:
      anomaly_threshold: 3.0

# Anomaly Detection
anomaly_detection:
  enabled: true
  algorithm: zscore
  zscore_threshold: 3.0
  window_size: 100
  min_samples: 30

# AI Incident Summaries
# Uses the OpenAI API (or any OpenAI-compatible endpoint).
# Disabled by default — set enabled: true and provide your API key to activate.
ai:
  enabled: false
  provider: "openai"
  api_url: "https://api.openai.com/v1/chat/completions"
  api_key: ""               # Your OpenAI API key (sk-...)
  model: "gpt-4o-mini"
  max_calls_per_hour: 10
  batch_window_ms: 120000   # Wait 2 min to batch alerts before summarising
  cooldown_per_server_ms: 900000  # 15 min between summaries per server

# Data Retention
retention:
  metrics_days: 30
  alerts_days: 90

# Logging
logging:
  level: info
  file: /app/logs/fenris.log
  max_size: 100MB
  max_files: 5
