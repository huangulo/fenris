# Fenris Environment Variables

# Server Configuration
PORT=3200
NODE_ENV=production

# Database Configuration
# WARNING: change this password before deploying — do not use the default
DATABASE_URL=postgresql://fenris:CHANGE_ME_BEFORE_DEPLOY@localhost:5432/fenris
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# Discord Alert Configuration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# Config File Path (optional)
FENRIS_CONFIG=/app/fenris.yaml
