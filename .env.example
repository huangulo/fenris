# Fenris Environment Variables
# Copy to .env and fill in your values before running docker compose.

# Server Configuration
PORT=3200
NODE_ENV=production

# Database
# WARNING: change CHANGE_ME_BEFORE_DEPLOY to a strong password before deploying
DATABASE_URL=postgresql://fenris:CHANGE_ME_BEFORE_DEPLOY@localhost:5432/fenris
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# Alert channels — set whichever you use; leave blank to disable
# Discord incoming webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Slack incoming webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Email / SMTP credentials (used by fenris.yaml smtp block)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password
ALERT_FROM=fenris@yourdomain.com
ALERT_TO=admin@yourdomain.com

# Docker socket GID on the host (used by docker-compose group_add)
# Run: stat -c '%g' /var/run/docker.sock
DOCKER_GID=988

# Config File Path (optional — defaults to /app/fenris.yaml inside container)
FENRIS_CONFIG=/app/fenris.yaml

# Frontend API key — must match a row in the servers.api_key column
# The seeded default is 'local-default-key'; change it for production
VITE_API_KEY=local-default-key
